# =============================================================================
# Git Vault Synchronization - Ignore Rules
# =============================================================================
# This file prevents sensitive data from being committed to the vault sync repo
# =============================================================================

# -----------------------------------------------------------------------------
# CRITICAL: Never commit these (security risk)
# -----------------------------------------------------------------------------

# Environment files with secrets
.env
.env.local
.env.*.local
.env.production
.env.cloud
.env.*

# Token and authentication files
*.token
*.auth
token.pickle
*.session
*.session3d

# Credential files
client_secret.json
gmail_credentials.json
credentials.json
*.pem
*.key
*.p12
*.pfx
secrets.json

# -----------------------------------------------------------------------------
# Session directories (NEVER sync)
# -----------------------------------------------------------------------------
sessions/
session/
*.session/
whatsapp_session/
venv/
ENV/
.env/

# -----------------------------------------------------------------------------
# Token directories (NEVER sync)
# -----------------------------------------------------------------------------
tokens/

# -----------------------------------------------------------------------------
# Build/dependency artifacts
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
node_modules/
venv/
ENV/

# -----------------------------------------------------------------------------
# IDE and editor files
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# Logs (except vault logs which are explicitly allowed)
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak

# -----------------------------------------------------------------------------
# Git sync metadata
# -----------------------------------------------------------------------------
.git/
.gitignore
.gitattributes
sync.sh
cron/
scripts/sync.sh
