# =============================================================================
# AI Employee - Gold Tier Configuration Template
# =============================================================================
# IMPORTANT: Copy this file to .env and fill in your actual credentials
# Command: cp .env.example .env (Linux/Mac) or copy .env.example .env (Windows)
# 
# SECURITY WARNING: Never commit .env file with real credentials!
# =============================================================================

# -----------------------------------------------------------------------------
# ODOO ERP CONFIGURATION (Docker)
# -----------------------------------------------------------------------------
ODOO_ADMIN_PASSWORD=YourSecureAdminPassword123!
ODOO_DB_PASSWORD=YourSecureDBPassword123!
ODOO_DB_USER=odoo
ODOO_DB_NAME=odoo_db
ODOO_HOST=0.0.0.0
ODOO_PORT=8069
ODOO_WORKERS=2
ODOO_MAX_MEMORY_LIMIT=2048
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=YourPgAdminPassword123!

# -----------------------------------------------------------------------------
# ODOO MCP SERVER CONFIGURATION
# -----------------------------------------------------------------------------
ODOO_URL=http://localhost:8069
ODOO_DB=odoo_db
ODOO_USERNAME=admin
ODOO_PASSWORD=YourSecureAdminPassword123!

# -----------------------------------------------------------------------------
# GMAIL API CONFIGURATION
# -----------------------------------------------------------------------------
GMAIL_CLIENT_ID=your-gmail-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=http://localhost:8080
GMAIL_TOKEN_FILE=gmail_token.json
GMAIL_CREDENTIALS_FILE=gmail_credentials.json
GMAIL_SENDER_EMAIL=your-email@gmail.com

# -----------------------------------------------------------------------------
# LINKEDIN CONFIGURATION
# -----------------------------------------------------------------------------
LINKEDIN_EMAIL=your-linkedin-email@example.com
LINKEDIN_PASSWORD=YourLinkedInPassword123!
LINKEDIN_USERNAME=your-linkedin-username
LINKEDIN_POST_SCHEDULE=0 9 * * 1-5

# -----------------------------------------------------------------------------
# FACEBOOK/INSTAGRAM CONFIGURATION
# -----------------------------------------------------------------------------
FACEBOOK_PAGES=YourBusinessPage
INSTAGRAM_ACCOUNTS=yourbusiness
FACEBOOK_ACCESS_TOKEN=your-facebook-access-token
FACEBOOK_PAGE_ID=your-page-id
FACEBOOK_APP_ID=your-app-id
FACEBOOK_APP_SECRET=your-app-secret
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your-ig-business-account-id

# -----------------------------------------------------------------------------
# TWITTER/X CONFIGURATION
# -----------------------------------------------------------------------------
TWITTER_USERNAME=YourUsername
TWITTER_EMAIL=your-twitter-email@example.com
TWITTER_PASSWORD=YourTwitterPassword123!
TWITTER_HASHTAGS=AI,Automation,MachineLearning
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-twitter-access-token-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# -----------------------------------------------------------------------------
# WHATSAPP CONFIGURATION
# -----------------------------------------------------------------------------
WHATSAPP_SESSION_PATH=./whatsapp_session
WHATSAPP_KEYWORDS=urgent,asap,invoice,payment,help

# -----------------------------------------------------------------------------
# CLAUDE CODE CONFIGURATION
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.7
RALPH_MAX_ITERATIONS=10
RALPH_MAX_DURATION_MINUTES=60

# -----------------------------------------------------------------------------
# AI EMPLOYEE SYSTEM CONFIGURATION
# -----------------------------------------------------------------------------
VAULT_PATH=AI_Employee_Vault
GMAIL_CHECK_INTERVAL=120
WHATSAPP_CHECK_INTERVAL=30
LINKEDIN_CHECK_INTERVAL=300
FACEBOOK_CHECK_INTERVAL=600
TWITTER_CHECK_INTERVAL=300
FILESYSTEM_CHECK_INTERVAL=60
APPROVAL_TIMEOUT_SECONDS=3600
APPROVAL_POLL_INTERVAL=10
LOG_LEVEL=INFO
LOG_FILE=logs/ai_employee.log
LOG_RETENTION_DAYS=90
MAX_RETRY_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=5

# -----------------------------------------------------------------------------
# CEO BRIEFING CONFIGURATION
# -----------------------------------------------------------------------------
CEO_BRIEFING_SCHEDULE=0 7 * * 1
BRIEFING_INCLUDE_FINANCIALS=true
BRIEFING_INCLUDE_SOCIAL=true
BRIEFING_INCLUDE_TASKS=true
BRIEFING_INCLUDE_BOTTLENECKS=true
BRIEFING_EMAIL_RECIPIENT=ceo@example.com
BRIEFING_EMAIL_ENABLED=false

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (PostgreSQL for Odoo)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=odoo
POSTGRES_PASSWORD=YourSecureDBPassword123!
POSTGRES_DB=odoo_db

# -----------------------------------------------------------------------------
# SECURITY SETTINGS
# -----------------------------------------------------------------------------
SOCIAL_AUTO_APPROVE_LIMIT=0
INVOICE_AUTO_APPROVE_LIMIT=0
PAYMENT_AUTO_APPROVE_LIMIT=0
EMAIL_NEW_CONTACT_APPROVAL=true

# -----------------------------------------------------------------------------
# CLOUD DEPLOYMENT (Platinum Tier - Optional)
# -----------------------------------------------------------------------------
CLOUD_PROVIDER=oracle
CLOUD_VM_IP=your-vm-ip-address
CLOUD_VM_SSH_KEY=~/.ssh/id_rsa
VAULT_SYNC_METHOD=git
VAULT_SYNC_REMOTE_URL=git@github.com:username/ai-employee-vault.git
VAULT_SYNC_BRANCH=main
VAULT_SYNC_INTERVAL=300
CLOUD_AGENT_MODE=false
LOCAL_AGENT_MODE=true

# -----------------------------------------------------------------------------
# MCP SERVER CONFIGURATION
# -----------------------------------------------------------------------------
MCP_EMAIL_ENABLED=true
MCP_LINKEDIN_ENABLED=true
MCP_FACEBOOK_ENABLED=true
MCP_TWITTER_ENABLED=true
MCP_ODOO_ENABLED=true
MCP_BROWSER_ENABLED=true
MCP_TIMEOUT=120
MCP_CONNECTION_TIMEOUT=30

# -----------------------------------------------------------------------------
# PERFORMANCE SETTINGS
# -----------------------------------------------------------------------------
MAX_WATCHER_THREADS=10
MAX_MEMORY_MB=2048
TASK_QUEUE_SIZE=100
HEALTH_CHECK_INTERVAL=60

# -----------------------------------------------------------------------------
# NOTIFICATION SETTINGS
# -----------------------------------------------------------------------------
ERROR_NOTIFICATION_EMAIL=admin@example.com
ERROR_NOTIFICATION_ENABLED=true
SLACK_WEBHOOK_URL=
SLACK_NOTIFICATION_ENABLED=false
DISCORD_WEBHOOK_URL=
DISCORD_NOTIFICATION_ENABLED=false

# -----------------------------------------------------------------------------
# DEVELOPMENT/DEBUG SETTINGS
# -----------------------------------------------------------------------------
DEBUG_MODE=false
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_SLOW_MO=1000
PLAYWRIGHT_TIMEOUT=30000
TEST_MODE=false
DRY_RUN=false

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
